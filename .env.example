# Copy to .env for local development: cp .env.example .env
# Never commit the real .env file.

SESSION_SECRET=replace-with-a-long-random-string
TMDB_API_KEY=your-tmdb-api-key
GOOGLE_API_KEY=your-google-books-api-key

# OAuth Client ID for "Sign in with Google" (console.cloud.google.com ->
# APIs & Services -> Credentials). Sign-in is disabled if unset.
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com

# Optional. Defaults to a local SQLite file (./matcher.db) if unset.
# Point at Postgres (e.g. Neon) in production.
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
